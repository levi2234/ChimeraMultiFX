	(text "- DAISY SEED:        				4- 17V to VIN  (Typ: ~50 mA  | Max: ~200 mA)\n- RASPBERRY PI ZERO: 				5.0V to 5V   (Typ: ~400 mA | Max: ~800 mA)  \n- ESP32:             				3.3V or 5V  (Typ: ~100 mA | Max: ~500 mA)   \n- TFT Touchscreen 	  				5.0V to 5V    (Type: ~500A | Max: ~1A)      \n- Peripherals (Led, I2C extenders)	3.3V (Typ: ~20 mA per component)            \n"
		(exclude_from_sim no)
		(at 179.324 26.162 0)
		(effects
			(font
				(size 1.27 1.27)
